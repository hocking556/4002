#### script for running RGI #####

#! /bin/bash
#SBATCH -D /mnt/shared/scratch/hhocking/
#SBATCH --job-name=rgi
#SBATCH --array=0-744
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --partition=hicpu
#SBATCH --mem=1G

source /mnt/apps/users/hhocking/conda/bin/activate /mnt/apps/users/hhocking/conda/envs/rgi_6.0.5

mapfile -t libraries < libs.txt

mkdir -p rgi_results_fna

rgi main -i /mnt/shared/scratch/hhocking/fna/${libraries[${SLURM_ARRAY_TASK_ID}]}.fna \
         -o rgi_results_fna/${libraries[${SLURM_ARRAY_TASK_ID}]} \
         -t contig \
         -a DIAMOND \
         --clean

