    present  = sum(1 for iso in isolate_names if isolate_summary[iso])
    absent   = len(missing_isolates)
    dual_tag = sum(1 for iso in isolate_names if len(isolate_summary[iso]) > 1)

    print(f"\n{'='*55}")
    print(f"  SUMMARY FOR GENE: {gene_name.upper()}")
    print(f"{'='*55}")
    print(f"  Total isolates                  : {total}")
    print(f"  Isolates with {gene_name} locus tag     : {present}")
    print(f"  Isolates with NO locus tag      : {absent}")
    print(f"  Isolates with >1 locus tag      : {dual_tag}  (potential nfsA+objC contamination)")
    print(f"  Locus tags not found in FAA     : {len(not_found)}")
    print(f"\n  Output files written to: {output_dir}")
    print(f"  - {gene_name}_all_sequences.faa")
    print(f"  - {gene_name}_locus_tag_summary.tsv")
    print(f"  - {gene_name}_missing_isolates.txt")
    print(f"  - {gene_name}_sequence_not_found.txt")
    print(f"{'='*55}\n")


def main():
    args = parse_args()

    print(f"\nReading presence/absence file: {args.presence_absence}")
    isolate_names, nfsa_rows = read_presence_absence(args.presence_absence, args.gene_name)

    if not nfsa_rows:
        sys.exit(f"ERROR: No rows matching '{args.gene_name}' found. Check gene name and CSV.")

    faa_index = index_faa_files(args.faa_dir, args.faa_ext, isolate_names)

    print("\nExtracting sequences...")
    isolate_summary, missing_isolates, not_found = extract_sequences(
        isolate_names, nfsa_rows, faa_index, args.gene_name, args.output_dir
    )

    print_summary(isolate_names, isolate_summary, missing_isolates, not_found,
                  args.output_dir, args.gene_name)


if __name__ == "__main__":
    main()
